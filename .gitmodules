[submodule "vendor/cmsis-core"]
	path = vendor/cmsis-core
	url = https://github.com/STMicroelectronics/cmsis-core.git
	shallow = true
[submodule "vendor/cmsis_device_l1"]
	path = vendor/cmsis_device_l1
	url = https://github.com/STMicroelectronics/cmsis_device_l1.git
	shallow = true
[submodule "vendor/stm32l1xx_hal_driver"]
	path = vendor/stm32l1xx_hal_driver
	url = https://github.com/STMicroelectronics/stm32l1xx_hal_driver.git
	shallow = true
[submodule "vendor/unity"]
	path = vendor/unity
	url = https://github.com/ThrowTheSwitch/Unity.git
